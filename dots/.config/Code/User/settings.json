{
  "telemetry.feedback.enabled": false,
  "telemetry.telemetryLevel": "off",

  // Title bar
  "workbench.layoutControl.enabled": false,
  "window.commandCenter": false,

  // Layout
  "workbench.activityBar.location": "top",
  "window.customTitleBarVisibility": "auto",
  "breadcrumbs.symbolPath": "off",

  // Color Theme
  "window.autoDetectColorScheme": true,
  "workbench.preferredDarkColorTheme": "Default Dark Modern",
  "workbench.preferredLightColorTheme": "Alt Catppuccin Latte",

  "workbench.colorCustomizations": {
    "[Default Dark Modern]": {
      "titleBar.activeBackground": "#202124",
      "titleBar.border": "#202124",
      "titleBar.inactiveBackground": "#202124",

      "tab.activeBackground": "#202124",
      "tab.activeBorder": "#202124",
      "tab.border": "#202124",
      "tab.inactiveBackground": "#202124",
      "tab.unfocusedActiveBorder": "#202124",

      "activityBar.background": "#202124",
      "activityBar.activeBorder": "#202124",
      "activityBar.border": "#202124",
      "activityBarTop.dropBorder": "#202124",
      "activityBarBadge.background": "#202124",

      "sideBarSectionHeader.border": "#202124",
      "sideBar.background": "#202124",
      "sideBar.border": "#20292D",

      "editor.background": "#202124",
      "editor.selectionForeground": "#202124",

      "editorGroup.border": "#20292D",
      "editorGroup.dropBackground": "#202124",
      "editorGroup.emptyBackground": "#202124",
      "editorGroupHeader.noTabsBackground": "#202124",
      "editorGroupHeader.tabsBackground": "#202124",
      "editorGroupHeader.tabsBorder": "#202124",

      "statusBar.background": "#202124",
      "statusBar.border": "#202124",

      "panel.background": "#202124",
      "editorRuler.foreground": "#20292D",
      "scrollbar.shadow": "#00000000",
    },
  },

  // Zen mode
  "zenMode.centerLayout": false,
  "zenMode.hideLineNumbers": false,
  "zenMode.fullScreen": false,
  "window.zoomLevel": 2,
  "window.menuBarVisibility": "toggle",
  "workbench.editor.decorations.colors": false,
  "workbench.editor.scrollToSwitchTabs": true,
  "workbench.editor.pinnedTabSizing": "compact",

  // Editor
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit",
  },
  "editor.suggestSelection": "first",
  "editor.inlineSuggest.enabled": true,
  "editor.fontFamily": "'Hack', 'Font Awesome 6 Free Solid'",
  "editor.detectIndentation": true,
  "editor.minimap.enabled": false,
  "editor.multiCursorModifier": "alt",
  "editor.wordSeparators": "`~!@#$%^&*()-=+[{]}\\|;:'\",.<>/?",

  // Languages
  "typescript.updateImportsOnFileMove.enabled": "always",
  "javascript.updateImportsOnFileMove.enabled": "always",

  "[typescript][javascript][json][jsonc][json5][html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.rulers": [80, 100, 120],
  },
  "[markdown]": {
    "editor.wordWrap": "off",
    "editor.wordWrapColumn": 80,
    "editor.rulers": [80, 100],
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[dockerfile]": {
    "editor.defaultFormatter": "ms-azuretools.vscode-docker",
    "editor.wordWrapColumn": 80,
    "editor.rulers": [80, 100],
  },
  "[shellscript][ignore][dotenv][properties]": {
    "editor.defaultFormatter": "mkhl.shfmt",
    "editor.wordWrapColumn": 80,
    "editor.rulers": [80, 100],
  },
  "[c][cpp]": {
    "editor.defaultFormatter": "ms-vscode.cpptools",
    "editor.wordWrapColumn": 80,
    "editor.rulers": [80],
  },
  "[rust]": {
    "editor.defaultFormatter": "rust-lang.rust-analyzer",
    "editor.wordWrapColumn": 80,
    "editor.rulers": [80],
  },
  "[tailwindcss]": {
    "editor.defaultFormatter": "bradlc.vscode-tailwindcss",
  },

  // Emmet
  "emmet.triggerExpansionOnTab": true,
  "emmet.includeLanguages": {
    "javascript": "javascriptreact",
  },

  // Rewrap
  "rewrap.wrappingColumn": 80,

  // Explorer
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.excludeGitIgnore": true,

  // Files
  "files.trimTrailingWhitespace": true,
  "files.eol": "\n",
  "files.associations": {
    ".env*": "toml",
  },

  // Tasks & Debug
  "task.autoDetect": "off",
  "task.quickOpen.showAll": false,
  "task.quickOpen.history": 0,

  // Terminal
  "terminal.integrated.shellIntegration.enabled": false,

  // Status bar
  "git.enableStatusBarSync": false,
  "debug.showInStatusBar": "never",

  // Copilot
  "inlineChat.lineNaturalLanguageHint": false,
  "github.copilot.enable": {
    "*": false,
    "plaintext": false,
    "markdown": false,
    "scminput": false,
  },
  "workbench.editor.empty.hint": "hidden",
  "chat.commandCenter.enabled": false,
  "workbench.secondarySideBar.defaultVisibility": "hidden",

  // Other
  "terminal.integrated.enableMultiLinePasteWarning": "never",
  "debug.onTaskErrors": "abort",
  "git.blame.editorDecoration.enabled": false,
  "diffEditor.ignoreTrimWhitespace": false,
  "window.newWindowProfile": "Default",

  // Extensions
  "gitlens.mode.active": "zen",
  "githubPullRequests.fileListLayout": "flat",
  "cmake.showConfigureWithDebuggerNotification": false,
  "playwright.reuseBrowser": true,
  "gitlens.plusFeatures.enabled": false,
  "todo.statistics.statusbar.enabled": false,
  "svelte.enable-ts-plugin": true,
}
