{
  "buffer_font_fallbacks": ["Font Awesome 6 Free Solid"],
  "buffer_font_family": "Hack",
  "file_types": { "toml": [".env*"] },
  "icon_theme": "Zed (Default)",

  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },

  // Theme
  "theme": {
    "mode": "dark",
    "light": "Gruvbox Light Soft",
    "dark": "One Dark"
  },

  // Panels
  "minimap": { "show": "never" },
  "project_panel": { "hide_gitignore": true, "hide_root": true },
  "collaboration_panel": { "button": false },
  "search": { "button": false },
  "outline_panel": { "expand_outlines_with_depth": 1 },

  // Editor
  "git": { "inline_blame": { "enabled": false } },
  "show_edit_predictions": true,

  // Keymap
  "vim_mode": false,
  "base_keymap": "VSCode",
  "multi_cursor_modifier": "alt",

  // Agent
  "agent": {
    "default_model": {
      "provider": "ollama",
      "model": "qwen3-coder:30b"
    },
    "model_parameters": []
  }
}
